<?xml version="1.0" encoding="UTF-8"?>
<includes>
    <!-- Fullscreen Wall -->
    <include name="Video_553_ThumbWall">
        <control type="group">
            <visible>Control.IsVisible(553)</visible>
            <include>ViewAnimation</include>

            <control type="image">
                <description>background image</description>
                <left>0</left>
                <top>-1400</top>
                <width>1920</width>
                <height>2500</height>
                <texture>back.png</texture>
                <colordiffuse>CC000000</colordiffuse>
            </control>

            <control type="panel" id="553">
                <width>100%</width>
                <height>1080</height>
                <onleft condition="Control.IsVisible(55360)">55360</onleft>
                <onleft condition="!Control.IsVisible(55360)">SetProperty(MediaMenu,True,home)</onleft>
                <onleft condition="!Control.IsVisible(55360)">SetFocus(9050)</onleft>
                <!-- Only works if ParentFolder item is disabled -->
                <onright>SetFocus(553,$INFO[Container(553).CurrentItem],absolute)</onright>
                <onup>553</onup>
                <ondown>553</ondown>
                <orientation>vertical</orientation>
                <viewtype label="Wall">icon</viewtype>
                <pagecontrol>55360</pagecontrol>
                <preloaditems>2</preloaditems>
                <scrolltime tween="quadratic">400</scrolltime>
                <visible>Container.Content(files)</visible>
                <itemlayout width="320" height="250">
                    <control type="group">
                        <top>60</top>
                        <control type="image">
                            <width>320</width>
                            <height>240</height>
                            <aspectratio scalediffuse="false">scale</aspectratio>
                            <texture background="true" fallback="special://skin/extras/moviegenres/Default.jpg">$VAR[PosterVar]</texture>
                  					<bordertexture border="20">thumbs/thumb_shadow.png</bordertexture>
                            <bordersize>20</bordersize>
                        </control>
                        <control type="label">
                            <left>10</left>
                            <top>234</top>
                            <width>300</width>
                            <height>20</height>
                            <font>font12</font>
                            <textcolor>grey</textcolor>
                            <selectedcolor>selected</selectedcolor>
                            <align>left</align>
                            <aligny>center</aligny>
                            <label>$INFO[ListItem.Label]</label>
                        </control>
                        <control type="image">
                            <width>320</width>
                            <height>240</height>
                            <texture border="1" colordiffuse="33FFFFFF">black.png</texture>
                            <bordersize>20</bordersize>
                        </control>
                    </control>
                </itemlayout>
                <focusedlayout width="320" height="240">
                    <control type="group">
                        <top>60</top>
                        <control type="image">
                            <width>320</width>
                            <height>240</height>
                            <aspectratio scalediffuse="false">scale</aspectratio>
                            <texture background="true" fallback="special://skin/extras/moviegenres/Default.jpg">$VAR[PosterVar]</texture>
                  					<bordertexture border="20">thumbs/thumb_shadow.png</bordertexture>
                            <bordersize>20</bordersize>
                        </control>
                        <control type="image">
                            <top>4</top>
                            <left>4</left>
                            <width>312</width>
                            <height>232</height>
                            <texture border="10">thumbs/thumbnail_focused.png</texture>
                            <bordersize>8</bordersize>
                            <animation effect="fade" start="100" end="0" time="200" reversible="false">UnFocus</animation>
                            <animation effect="fade" start="0" end="100" time="200" reversible="false">Focus</animation>
                        </control>
                        <control type="label">
                            <left>10</left>
                            <top>240</top>
                            <width>300</width>
                            <height>20</height>
                            <font>font12</font>
                            <textcolor>grey</textcolor>
                            <selectedcolor>selected</selectedcolor>
                            <align>left</align>
                            <aligny>center</aligny>
                            <label>$INFO[ListItem.Label]</label>
                        </control>
                    </control>
                </focusedlayout>
            </control>
            <control type="scrollbar" id="55360">
                <left>-4</left>
                <width>14</width>
                <height>100%</height>
                <onup>55360</onup>
                <ondown>55360</ondown>
                <onleft>SetProperty(MediaMenu,True,home)</onleft>
                <onleft>SetFocus(9050)</onleft>
                <onright>553</onright>
                <texturesliderbackground />
                <texturesliderbar colordiffuse="55ffffff" border="1">scrollbar/texturesliderbar2.png</texturesliderbar>
                <texturesliderbarfocus border="1">scrollbar/texturesliderbar2.png</texturesliderbarfocus>
                <showonepage>false</showonepage>
                <orientation>vertical</orientation>
            </control>
        </control>
    </include>
    <include name="UpDownShadow">
        <control type="group">
            <animation effect="fade" time="300">WindowOpen</animation>
            <animation effect="fade" time="300">WindowClose</animation>
            <visible>Control.IsVisible(553)</visible>
            <control type="image">
                <width>100%</width>
                <height>120</height>
                <texture border="1">bottom_shadow.png</texture>
            </control>
            <control type="image">
                <top>960</top>
                <width>100%</width>
                <height>120</height>
                <texture border="1" flipy="true">bottom_shadow.png</texture>
            </control>
        </control>
    </include>
</includes>
